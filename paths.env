# Single source of truth for filesystem paths used by this repo.
# Format:  KEY=VALUE  (no spaces around =, no quotes needed unless you want them).
# Lines starting with '#' are comments; blank lines are ignored.
#
# Loading order (later overrides earlier):
#   1. defaults baked into aggregation/config.py and segmentation/config.py
#   2. values from this file (loaded by paths.py)
#   3. real environment variables exported in your shell
#
# Edit this file once, get consistent paths everywhere — Python configs and
# scripts/setup_hennepin.sh all read it.

# ----- Aggregation pipeline (the main models) -----

# Root of the unpacked aggregation dataset. After running scripts/setup_hennepin.sh,
# this directory contains 1m_302px/{imgs,masks,vals.pkl} and
# 1m_302px_region_combined/{imgs,masks,vals.pkl}.
HENNEPIN_DATA_ROOT=

# Subdirectory names inside HENNEPIN_DATA_ROOT. Match the directory layer that
# unzipping each archive creates.
HENNEPIN_UNCOMBINED_SUBDIR=1m_302px
HENNEPIN_COMBINED_SUBDIR=1m_302px_region_combined

# Pretrained backbone checkpoint loaded when cfg.train.use_pretrained=True.
# Produced by segmentation/train.py. Leave empty to use the default
# (segmentation/outputs/buildsegpretrain/building_seg_pretrained.pth).
PRETRAINED_CKPT=

# ----- Setup script -----

# Directory containing the Box-synced 1m_302px*.zip archives.
BOX_DIR=

# ----- Segmentation pre-training (optional, not in Box) -----
#
# The `ver8/` raw layout has per-tile subdirs keyed by lat_mid/lon_mid containing
# building_mask.tif, parcel_boundary.tif, parcel_mask.tif, <lat>_<lon>.tif,
# parcel_value.tif. This data is NOT in the Box archives — it lives on the
# cluster where the dataset was originally compiled. Set these only if you have
# that data and want to retrain the segmentation backbone.

HENNEPIN_VER8_ROOT=
# Default points to the recovered bbox catalog at dataset_generation/hennepin_bbox.csv
# (5501 tiles, restored from git history). Override only if you generate a different one.
HENNEPIN_VER8_CSV=
SEG_OUT_DIR=

# ----- Dataset regeneration (rarely used) -----
#
# Used by dataset_generation/hennepin_compile.py to rebuild the compiled archives
# from the ver8/-style raw data. Set HENNEPIN_COMBINE=0 to skip parcel combining.

HENNEPIN_RAW_ROOT=
HENNEPIN_PARCEL_SHP=
HENNEPIN_COMPILED_OUT=
HENNEPIN_COMBINE=1

# Used by dataset_generation/extended_sets.py (style-transfer experiment).
HENNEPIN_2020_ROOT=
HENNEPIN_2018_ROOT=
